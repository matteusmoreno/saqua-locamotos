# ============================================================
#  Saqua Locamotos — Variáveis de Ambiente
#  Copie este arquivo para .env e preencha os valores reais
# ============================================================

# ── App ──────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:9292
APP_SAQUA_LOCAMOTOS_TIMEZONE=America/Sao_Paulo
APP_SAQUA_LOCAMOTOS_TOKEN_EXPIRATION_HOURS=24

# ── MongoDB (Atlas) ──────────────────────────────────────────
DBAAS_MONGODB_ENDPOINT=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/
DBAAS_MONGODB_DBNAME=saqua-locamotos

# ── Cloudinary ───────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── E-mail (SMTP Gmail) ───────────────────────────────────────
MAILER_FROM=relacionamento@saqualocamotos.com.br
MAILER_HOST=smtp.gmail.com
MAILER_PORT=587
MAILER_USERNAME=your-gmail@gmail.com
MAILER_PASSWORD=your-app-password

